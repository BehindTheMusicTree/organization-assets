# Required for `npm run playground` / root `npm run build`:
# `scripts/run-playground.mjs` reads ORG_URL from here when the shell does not set it.
# Same value as GitHub repository variable DOMAIN_NAME (hostname or https URL).
ORG_URL=https://themusictree.org

# Playground social icon row: Vite embeds these at dev/build time from this file (or the shell env).
BTMT_GITHUB_LINK=https://github.com/BehindTheMusicTree
LINKEDIN_URL=https://www.linkedin.com/in/your-handle
MASTODON_URL=https://mastodon.social/@yourhandle
CONTACT_EMAIL=you@example.com

# Optional — omit or leave empty to hide that icon (LINKEDIN_URL etc. may omit https://; it is added).
BTMT_DOCS_URL=
BTMT_GITHUB_REPO=https://github.com/BehindTheMusicTree/organization-assets
BTMT_PYPI_LINK=
BTMT_X_URL=
BTMT_YOUTUBE_URL=
BTMT_SUPPORT_URL=
